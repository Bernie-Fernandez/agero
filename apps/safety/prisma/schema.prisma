// Prisma schema — Agero safety platform (Supabase Postgres)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  safety_manager
  project_manager
  site_manager
  subcontractor_admin
}

enum DocumentType {
  public_liability
  workers_compensation
  contract_works
  professional_indemnity
  whs_policy
  white_card
  trade_licence
  first_aid
  swms
  other
}

enum InductionType {
  generic
  site_specific
}

enum InviteStatus {
  pending
  registered
  expired
}

enum WorkerInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum CredentialType {
  WHITE_CARD
  HRWL_SCAFFOLD
  HRWL_CRANE
  HRWL_FORKLIFT
  HRWL_EWP
  HRWL_DOGGING
  HRWL_RIGGING
  HRWL_CONFINED_SPACE
  HRWL_EXPLOSIVE
  HRWL_OTHER
  TRADE_CERTIFICATE
  FIRST_AID
  ASBESTOS_AWARENESS
  DRIVER_LICENCE
  PASSPORT
  GOVERNMENT_ID
  TRAINING_CERTIFICATE
  OTHER
}

enum ConsultationEventType {
  SWMS_APPROVAL
  INDUCTION
  TOOLBOX_MEETING
  NCR
  PRE_START_INTERNAL
}

enum SitePreparationPlanStatus {
  DRAFT
  COMPLETE
}

enum SwmsStatus {
  pending_review
  approved
  rejected
}

enum SwmsQuestionStatus {
  pending_review
  approved
  rejected
}

model Organisation {
  id               String      @id @default(uuid()) @db.Uuid
  name             String
  abn              String?
  logoUrl          String?     @map("logo_url")
  isActive         Boolean     @default(true) @map("is_active")
  tradeCategory    String?     @map("trade_category")
  tradeCategories  String[]    @map("trade_categories")
  primaryContact   String?     @map("primary_contact")
  website          String?
  address          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                   User[]
  projects                Project[]
  subcontractorOnProjects ProjectSubcontractor[] @relation("ProjectSubcontractorOrg")
  employedWorkers         Worker[]               @relation("WorkerEmployer")
  tenantWorkers           Worker[]               @relation("WorkerTenant")
  safetyProjects          SafetyProject[]
  documents               DocumentUpload[]
  supervisorRoles         SiteSupervisor[]
  invitations             Invitation[]
  swmsSubmissions         SwmsSubmission[]
  swmsInductionQuestions  SwmsInductionQuestion[]
  workerCredentials       WorkerCredential[]      @relation("WorkerCredentialOrg")
  swmsDocuments           SwmsDocument[]          @relation("SwmsDocumentOrg")
  workerInvitations       WorkerInvitation[]      @relation("WorkerInvitationOrg")
  complexityTemplates     ComplexityTemplate[]

  @@map("organisations")
}

model Invitation {
  id             String       @id @default(uuid()) @db.Uuid
  companyName    String       @map("company_name")
  contactName    String       @map("contact_name")
  email          String
  mobile          String?
  tradeCategories String[]     @default([]) @map("trade_categories")
  projectId       String?      @map("project_id") @db.Uuid
  token          String       @unique
  status         InviteStatus @default(pending)
  organisationId String?      @map("organisation_id") @db.Uuid
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  invitedBy      String       @map("invited_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  expiresAt      DateTime     @map("expires_at")

  @@index([token])
  @@map("invitations")
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  clerkUserId    String?      @unique @map("clerk_user_id")
  email          String       @unique
  name           String?
  role           UserRole     @default(site_manager)
  organisationId String       @map("organisation_id") @db.Uuid
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  preStartAssessments       PreStartAssessment[]       @relation("PreStartCompletedBy")
  sitePreparationChecklists SitePreparationChecklist[] @relation("SiteChecklistCompletedBy")
  hrwWarningAcks            HrwWarningAck[]            @relation("HrwWarningAckBy")

  @@index([organisationId])
  @@map("users")
}

model Project {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  address        String?
  token          String       @unique @default(uuid()) @db.Uuid
  organisationId String       @map("organisation_id") @db.Uuid
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  subcontractors         ProjectSubcontractor[]
  workers                Worker[]
  inductionTemplates     InductionTemplate[]
  startDate              DateTime?              @map("start_date")
  endDate                DateTime?              @map("end_date")
  status                 String                 @default("active")

  siteVisits             SiteVisit[]
  supervisors            SiteSupervisor[]
  documents              DocumentUpload[]
  swmsSubmissions        SwmsSubmission[]
  swmsInductionQuestions SwmsInductionQuestion[]

  @@index([organisationId])
  @@map("projects")
}

model ProjectSubcontractor {
  id                 String       @id @default(uuid()) @db.Uuid
  projectId          String       @map("project_id") @db.Uuid
  project            Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subcontractorOrgId String       @map("subcontractor_org_id") @db.Uuid
  subcontractorOrg   Organisation @relation("ProjectSubcontractorOrg", fields: [subcontractorOrgId], references: [id], onDelete: Cascade)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@unique([projectId, subcontractorOrgId])
  @@index([subcontractorOrgId])
  @@map("project_subcontractors")
}

model Worker {
  id                      String        @id @default(uuid()) @db.Uuid
  projectId               String        @map("project_id") @db.Uuid
  project                 Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employingOrganisationId String?       @map("employing_organisation_id") @db.Uuid
  employingOrganisation   Organisation? @relation("WorkerEmployer", fields: [employingOrganisationId], references: [id], onDelete: SetNull)
  organisationId          String?       @map("organisation_id") @db.Uuid
  organisation            Organisation? @relation("WorkerTenant", fields: [organisationId], references: [id], onDelete: SetNull)
  firstName               String        @map("first_name")
  lastName                String        @map("last_name")
  mobile                  String?
  email                   String?
  trade                   String?
  whiteCardNo             String?       @map("white_card_no")
  whiteCardExpiry         DateTime?     @map("white_card_expiry")
  nokName                 String?       @map("nok_name")
  nokPhone                String?       @map("nok_phone")
  nokRelationship         String?       @map("nok_relationship")
  credentialPhotoUrls     Json?         @map("credential_photo_urls")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  documents             DocumentUpload[]
  inductionCompletions  InductionCompletion[]
  siteVisits            SiteVisit[]
  supervisorRoles       SiteSupervisor[]
  credentials           WorkerCredential[]
  swmsSignatures        WorkerSwmsSignature[]
  mobBlockNotifications MobBlockNotification[]

  @@index([projectId])
  @@index([employingOrganisationId])
  @@index([organisationId])
  @@map("workers")
}

model DocumentUpload {
  id                 String        @id @default(uuid()) @db.Uuid
  type               DocumentType
  url                String
  expiryDate         DateTime?     @map("expiry_date")
  aiExtractedExpiry  Boolean       @default(false) @map("ai_extracted_expiry")
  coverageAmount     String?       @map("coverage_amount")
  verified           Boolean       @default(false)
  organisationId     String?       @map("organisation_id") @db.Uuid
  organisation       Organisation? @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  workerId           String?       @map("worker_id") @db.Uuid
  worker             Worker?       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  projectId          String?       @map("project_id") @db.Uuid
  project            Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@index([organisationId])
  @@index([workerId])
  @@index([projectId])
  @@map("document_uploads")
}

model SwmsSubmission {
  id               String       @id @default(uuid()) @db.Uuid
  projectId        String       @map("project_id") @db.Uuid
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organisationId   String       @map("organisation_id") @db.Uuid
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  fileUrl          String       @map("file_url")
  status           SwmsStatus   @default(pending_review)
  aiScanResults    Json?        @map("ai_scan_results")
  aiRecommendation String?      @map("ai_recommendation")
  reviewedBy       String?      @map("reviewed_by")
  reviewedAt       DateTime?    @map("reviewed_at")
  reviewerComments String?      @map("reviewer_comments")
  submittedAt      DateTime     @default(now()) @map("submitted_at")
  versionNumber    Int          @default(1) @map("version_number")

  @@index([projectId])
  @@index([organisationId])
  @@map("swms_submissions")
}

model InductionTemplate {
  id        String        @id @default(uuid()) @db.Uuid
  title     String
  type      InductionType
  version   Int           @default(1)
  isActive  Boolean       @default(true) @map("is_active")
  videoUrl  String?       @map("video_url")
  questions Json
  projectId String?       @map("project_id") @db.Uuid
  project   Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  completions InductionCompletion[]

  @@index([projectId])
  @@map("induction_templates")
}

model InductionCompletion {
  id         String            @id @default(uuid()) @db.Uuid
  workerId   String            @map("worker_id") @db.Uuid
  worker     Worker            @relation(fields: [workerId], references: [id], onDelete: Cascade)
  templateId String            @map("template_id") @db.Uuid
  template   InductionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  score      Int?
  passed     Boolean
  signedAt   DateTime          @map("signed_at")
  attempts   Int               @default(0)
  blockedUntil     DateTime?   @map("blocked_until")
  declarationSignedAt DateTime? @map("declaration_signed_at")
  declarationIp    String?     @map("declaration_ip")
  declarationData  Json?       @map("declaration_data")
  createdAt  DateTime          @default(now()) @map("created_at")

  @@unique([workerId, templateId])
  @@index([templateId])
  @@map("induction_completions")
}

model SiteVisit {
  id           String    @id @default(uuid()) @db.Uuid
  workerId     String    @map("worker_id") @db.Uuid
  worker       Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  projectId    String    @map("project_id") @db.Uuid
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  signedInAt   DateTime  @default(now()) @map("signed_in_at")
  signedOutAt  DateTime? @map("signed_out_at")
  photoUrl     String?   @map("photo_url")
  verified     Boolean   @default(false)
  verifiedBy   String?   @map("verified_by")
  verifiedAt   DateTime? @map("verified_at")
  isUnknown    Boolean   @default(false) @map("is_unknown")

  alert VerificationAlert?

  @@index([workerId])
  @@index([projectId])
  @@map("site_visits")
}

model SiteSupervisor {
  id             String       @id @default(uuid()) @db.Uuid
  workerId       String       @map("worker_id") @db.Uuid
  worker         Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)
  projectId      String       @map("project_id") @db.Uuid
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organisationId String       @map("organisation_id") @db.Uuid
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([projectId, organisationId])
  @@index([workerId])
  @@index([organisationId])
  @@map("site_supervisors")
}

model VerificationAlert {
  id          String    @id @default(uuid()) @db.Uuid
  siteVisitId String    @unique @map("site_visit_id") @db.Uuid
  siteVisit   SiteVisit @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)
  alertedAt   DateTime  @default(now()) @map("alerted_at")
  verifiedAt  DateTime? @map("verified_at")
  escalatedAt DateTime? @map("escalated_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("verification_alerts")
}

model WorkerAccount {
  id                 String    @id @default(uuid()) @db.Uuid
  mobile             String    @unique
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  trades             String[]  @default([])
  whiteCardNumber    String?   @map("white_card_number")
  whiteCardExpiry    DateTime? @map("white_card_expiry")
  tradeLicenceNumber String?   @map("trade_licence_number")
  tradeLicenceExpiry DateTime? @map("trade_licence_expiry")
  firstAidCertNumber String?   @map("first_aid_cert_number")
  firstAidExpiry     DateTime? @map("first_aid_expiry")
  dateOfBirth        DateTime? @map("date_of_birth")
  addressStreet      String?   @map("address_street")
  addressSuburb      String?   @map("address_suburb")
  addressState       String?   @map("address_state")
  addressPostcode    String?   @map("address_postcode")
  nokName            String?   @map("nok_name")
  nokRelationship    String?   @map("nok_relationship")
  nokMobile          String?   @map("nok_mobile")
  medicalConditions  String?   @map("medical_conditions")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  sessions               WorkerSession[]
  certDocuments          WorkerCertDocument[]
  buildingMgmtInductions BuildingMgmtInduction[]
  privacyConsent         WorkerPrivacyConsent?

  @@map("worker_accounts")
}

model WorkerSession {
  id              String        @id @default(uuid()) @db.Uuid
  workerAccountId String        @map("worker_account_id") @db.Uuid
  workerAccount   WorkerAccount @relation(fields: [workerAccountId], references: [id], onDelete: Cascade)
  token           String        @unique @default(uuid()) @db.Uuid
  expiresAt       DateTime      @map("expires_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([workerAccountId])
  @@map("worker_sessions")
}

model SmsVerification {
  id        String   @id @default(uuid()) @db.Uuid
  mobile    String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([mobile])
  @@map("sms_verifications")
}

model WorkerCertDocument {
  id                String        @id @default(uuid()) @db.Uuid
  workerAccountId   String        @map("worker_account_id") @db.Uuid
  workerAccount     WorkerAccount @relation(fields: [workerAccountId], references: [id], onDelete: Cascade)
  docType           String        @map("doc_type")
  url               String
  filename          String?
  expiryDate        DateTime?     @map("expiry_date")
  aiExtractedExpiry Boolean       @default(false) @map("ai_extracted_expiry")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@index([workerAccountId])
  @@map("worker_cert_documents")
}

model SwmsInductionQuestion {
  id                    String             @id @default(uuid()) @db.Uuid
  projectId             String             @map("project_id") @db.Uuid
  project               Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organisationId        String             @map("organisation_id") @db.Uuid
  organisation          Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  question              String
  expectedAnswerContext String             @map("expected_answer_context")
  status                SwmsQuestionStatus @default(pending_review)
  sortOrder             Int                @default(0) @map("sort_order")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([organisationId])
  @@map("swms_induction_questions")
}

// ─────────────────────────────────────────────────────────────────────────────
// SPRINT S1 — Project Safety Readiness Framework
// ─────────────────────────────────────────────────────────────────────────────

enum SafetyProjectStatus {
  SETUP
  ACTIVE
  COMPLETE
}

// Bridge table synced from ERP Project records.
// erp_project_id stores the UUID from the projects.projects table (cross-schema,
// so stored as String rather than a typed FK).
model SafetyProject {
  id                           String              @id @default(uuid()) @db.Uuid
  erpProjectId                 String              @unique @map("erp_project_id")
  organisationId               String              @map("organisation_id") @db.Uuid
  organisation                 Organisation        @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name                         String
  address                      String?
  status                       SafetyProjectStatus @default(SETUP)
  qrToken                      String              @unique @default(uuid()) @map("qr_token") @db.Uuid
  buildingMgmtInductionRequired Boolean            @default(false) @map("building_mgmt_induction_required")
  mobilisationDate             DateTime?           @map("mobilisation_date")
  createdAt                    DateTime            @default(now()) @map("created_at")
  updatedAt                    DateTime            @updatedAt @map("updated_at")

  preStartAssessments       PreStartAssessment[]
  sitePreparationChecklists SitePreparationChecklist[]
  buildingMgmtInductions    BuildingMgmtInduction[]
  swmsDocuments             SwmsDocument[]
  workerSwmsSignatures      WorkerSwmsSignature[]
  workerInvitations         WorkerInvitation[]
  sitePreparationPlan       SitePreparationPlan?
  hrwWarningAcks            HrwWarningAck[]
  mobBlockNotifications     MobBlockNotification[]
  consultationEvents        ConsultationEvent[]
  floorPlan                 ProjectFloorPlan?

  @@index([organisationId])
  @@map("safety_projects")
}

// Completed by the Site Manager one week before site establishment.
// Covers VIC OHS Regs 2017 Schedule 1 (17 HRW classifications) and
// VIC OHS (Psychological Health) Regulations 2025 (5 psychosocial categories).
model PreStartAssessment {
  id                 String        @id @default(uuid()) @db.Uuid
  projectId          String        @map("project_id") @db.Uuid
  project            SafetyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  completedById      String        @map("completed_by_id") @db.Uuid
  completedBy        User          @relation("PreStartCompletedBy", fields: [completedById], references: [id], onDelete: Cascade)
  assessmentDate     DateTime      @map("assessment_date") @db.Date
  highRiskFlags      Json          @map("high_risk_flags")
  psychosocialFlags  Json          @map("psychosocial_flags")
  consultationRecord            String?  @map("consultation_record") @db.Text
  projectComplexities           Json?    @map("project_complexities")
  signOffName                   String   @map("sign_off_name")
  signOffDropdownUserId         String?  @map("sign_off_dropdown_user_id")
  signatureUrl                  String?  @map("signature_url")
  signOffAt                     DateTime @map("sign_off_at")
  pdfUrl                        String?  @map("pdf_url")
  internalSignoffsRequired      Json?    @map("internal_signoffs_required")
  allInternalSigned             Boolean  @default(false) @map("all_internal_signed")
  createdAt                     DateTime @default(now()) @map("created_at")

  internalSignOffs InternalSignOff[]

  @@index([projectId])
  @@map("pre_start_assessments")
}

// Completed on day 1 of site establishment by the Site Manager on-site.
// Locked until PreStartAssessment is signed. 52 items across 10 categories.
model SitePreparationChecklist {
  id                 String        @id @default(uuid()) @db.Uuid
  projectId          String        @map("project_id") @db.Uuid
  project            SafetyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  completedById      String        @map("completed_by_id") @db.Uuid
  completedBy        User          @relation("SiteChecklistCompletedBy", fields: [completedById], references: [id], onDelete: Cascade)
  completionDate     DateTime             @map("completion_date") @db.Date
  items              Json
  planId             String?              @map("plan_id") @db.Uuid
  plan               SitePreparationPlan? @relation(fields: [planId], references: [id])
  sectionsComplete   Json?                @map("sections_complete")
  managerSignOffName String               @map("manager_sign_off_name")
  managerSignOffAt   DateTime             @map("manager_sign_off_at")
  signatureUrl       String?              @map("signature_url")
  pdfUrl             String?              @map("pdf_url")
  createdAt          DateTime             @default(now()) @map("created_at")

  @@index([projectId])
  @@map("site_preparation_checklists")
}

// Tracks per-worker completion of building-management induction,
// required when SafetyProject.buildingMgmtInductionRequired = true.
model BuildingMgmtInduction {
  id              String        @id @default(uuid()) @db.Uuid
  projectId       String        @map("project_id") @db.Uuid
  project         SafetyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workerAccountId String        @map("worker_account_id") @db.Uuid
  workerAccount   WorkerAccount @relation(fields: [workerAccountId], references: [id], onDelete: Cascade)
  completedAt     DateTime      @map("completed_at")
  completedByName String        @map("completed_by_name")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@unique([projectId, workerAccountId])
  @@index([workerAccountId])
  @@map("building_mgmt_inductions")
}

// ─────────────────────────────────────────────────────────────────────────────
// SPRINT S1.1 — Safety Workflow Fixes and Enhancements
// ─────────────────────────────────────────────────────────────────────────────

// Credential register per worker — photo evidence, AI-extracted data, expiry tracking.
model WorkerCredential {
  id               String         @id @default(uuid()) @db.Uuid
  workerId         String         @map("worker_id") @db.Uuid
  worker           Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  organisationId   String?        @map("organisation_id") @db.Uuid
  organisation     Organisation?  @relation("WorkerCredentialOrg", fields: [organisationId], references: [id], onDelete: SetNull)
  credentialType   CredentialType @map("credential_type")
  credentialNumber String?        @map("credential_number")
  issuingBody      String?        @map("issuing_body")
  issueDate        DateTime?      @map("issue_date")
  expiryDate       DateTime?      @map("expiry_date")
  isVerified       Boolean        @default(false) @map("is_verified")
  photoUrl         String?        @map("photo_url")
  notes            String?
  isWorkerEntered  Boolean        @default(true) @map("is_worker_entered")
  enteredByRole    String         @default("WORKER") @map("entered_by_role")
  aiExtracted      Boolean        @default(false) @map("ai_extracted")
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([workerId])
  @@index([organisationId])
  @@map("worker_credentials")
}

// SWMS registry — multiple documents per project per subcontractor, Agero approval.
model SwmsDocument {
  id              String        @id @default(uuid()) @db.Uuid
  projectId       String        @map("project_id") @db.Uuid
  project         SafetyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organisationId  String        @map("organisation_id") @db.Uuid
  organisation    Organisation  @relation("SwmsDocumentOrg", fields: [organisationId], references: [id], onDelete: Cascade)
  tradeCategory   String        @map("trade_category")
  documentUrl     String        @map("document_url")
  aiReviewResult  Json?         @map("ai_review_result")
  aiReviewPassed  Boolean?      @map("ai_review_passed")
  ageroApproved   Boolean?      @map("agero_approved")
  ageroApprovedBy String?       @map("agero_approved_by")
  ageroApprovedAt DateTime?     @map("agero_approved_at")
  version         Int           @default(1)
  isCurrent       Boolean       @default(true) @map("is_current")
  createdAt       DateTime      @default(now()) @map("created_at")

  workerSignatures WorkerSwmsSignature[]

  @@index([projectId])
  @@index([organisationId])
  @@map("swms_documents")
}

// Records a worker's digital acknowledgement of a specific SWMS version.
model WorkerSwmsSignature {
  id             String        @id @default(uuid()) @db.Uuid
  workerId       String        @map("worker_id") @db.Uuid
  worker         Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  swmsDocumentId String        @map("swms_document_id") @db.Uuid
  swmsDocument   SwmsDocument  @relation(fields: [swmsDocumentId], references: [id], onDelete: Cascade)
  projectId      String        @map("project_id") @db.Uuid
  project        SafetyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  signedAt       DateTime      @map("signed_at")
  signatureUrl   String?       @map("signature_url")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([workerId])
  @@index([swmsDocumentId])
  @@index([projectId])
  @@map("worker_swms_signatures")
}

// Subcontractor admin invites a worker to a project via Twilio SMS.
model WorkerInvitation {
  id             String             @id @default(uuid()) @db.Uuid
  projectId      String             @map("project_id") @db.Uuid
  project        SafetyProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organisationId String             @map("organisation_id") @db.Uuid
  organisation   Organisation       @relation("WorkerInvitationOrg", fields: [organisationId], references: [id], onDelete: Cascade)
  mobile         String
  invitedBy      String             @map("invited_by")
  invitedAt      DateTime           @default(now()) @map("invited_at")
  status         WorkerInviteStatus @default(PENDING)
  acceptedAt     DateTime?          @map("accepted_at")
  token          String             @unique
  expiresAt      DateTime           @map("expires_at")
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([projectId])
  @@index([organisationId])
  @@index([mobile])
  @@map("worker_invitations")
}

// Phase 1 of site preparation — planning form, completed before site establishment.
model SitePreparationPlan {
  id           String                    @id @default(uuid()) @db.Uuid
  projectId    String                    @unique @map("project_id") @db.Uuid
  project      SafetyProject             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    String                    @map("created_by")
  sections     Json
  status       SitePreparationPlanStatus @default(DRAFT)
  completedAt  DateTime?                 @map("completed_at")
  signatureUrl String?                   @map("signature_url")
  signOffName  String?                   @map("sign_off_name")
  signOffAt    DateTime?                 @map("sign_off_at")
  floorPlanId  String?                   @map("floor_plan_id") @db.Uuid
  floorPlan    ProjectFloorPlan?         @relation(fields: [floorPlanId], references: [id], onDelete: SetNull)
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")

  checklists SitePreparationChecklist[]
  pins       SitePreparationPin[]

  @@map("site_preparation_plans")
}

// One acknowledgement per HRW classification per project.
// Cleared automatically when a licensed worker is added; acknowledgement provides an audit trail.
model HrwWarningAck {
  id                  String        @id @default(uuid()) @db.Uuid
  safetyProjectId     String        @map("safety_project_id") @db.Uuid
  safetyProject       SafetyProject @relation(fields: [safetyProjectId], references: [id], onDelete: Cascade)
  hrwClassificationId String        @map("hrw_classification_id")
  acknowledgedById    String        @map("acknowledged_by_id") @db.Uuid
  acknowledgedBy      User          @relation("HrwWarningAckBy", fields: [acknowledgedById], references: [id], onDelete: Cascade)
  acknowledgedAt      DateTime      @default(now()) @map("acknowledged_at")
  note                String?

  @@unique([safetyProjectId, hrwClassificationId])
  @@index([safetyProjectId])
  @@map("hrw_warning_acks")
}

// One row per (worker, safetyProject) block event — used to deduplicate
// SMS + email notifications to 24 hours.
model MobBlockNotification {
  id              String        @id @default(uuid()) @db.Uuid
  workerId        String        @map("worker_id") @db.Uuid
  worker          Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  safetyProjectId String        @map("safety_project_id") @db.Uuid
  safetyProject   SafetyProject @relation(fields: [safetyProjectId], references: [id], onDelete: Cascade)
  sentAt          DateTime      @default(now()) @map("sent_at")

  @@index([workerId, safetyProjectId])
  @@map("mob_block_notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// SPRINT S1.2 — World-Class Safety Improvements
// ─────────────────────────────────────────────────────────────────────────────

// Admin-managed complexity templates for common fitout risks.
// Pre-populated in pre-start form complexity section.
model ComplexityTemplate {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @map("organisation_id") @db.Uuid
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name           String
  riskLevel      String       @map("risk_level")
  safetyPlanning String       @map("safety_planning") @db.Text
  hrwFlag        String?      @map("hrw_flag")
  tradeCategory  String?      @map("trade_category")
  isActive       Boolean      @default(true) @map("is_active")
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organisationId])
  @@map("complexity_templates")
}

// Tags all consultation touchpoints for auto-population of Panel B.
model ConsultationEvent {
  id               String                @id @default(uuid()) @db.Uuid
  projectId        String                @map("project_id") @db.Uuid
  project          SafetyProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  eventType        ConsultationEventType @map("event_type")
  referenceId      String                @map("reference_id")
  consultedPersons Json                  @map("consulted_persons")
  notes            String?               @db.Text
  eventDate        DateTime              @map("event_date")
  createdAt        DateTime              @default(now()) @map("created_at")

  @@index([projectId])
  @@map("consultation_events")
}

// Digital sign-off by a required internal signatory on a PreStartAssessment.
model InternalSignOff {
  id               String             @id @default(uuid()) @db.Uuid
  preStartId       String             @map("pre_start_id") @db.Uuid
  preStart         PreStartAssessment @relation(fields: [preStartId], references: [id], onDelete: Cascade)
  signatoryClerkId String             @map("signatory_clerk_id")
  signatoryName    String             @map("signatory_name")
  signatoryRole    String             @map("signatory_role")
  signatureUrl     String             @map("signature_url")
  signedAt         DateTime           @map("signed_at")

  @@index([preStartId])
  @@map("internal_sign_offs")
}

// One floor plan per project, shared by site prep, dilapidation, defects.
model ProjectFloorPlan {
  id              String        @id @default(uuid()) @db.Uuid
  safetyProjectId String        @unique @map("safety_project_id") @db.Uuid
  safetyProject   SafetyProject @relation(fields: [safetyProjectId], references: [id], onDelete: Cascade)
  fileUrl         String        @map("file_url")
  fileName        String        @map("file_name")
  uploadedBy      String        @map("uploaded_by")
  uploadedAt      DateTime      @default(now()) @map("uploaded_at")

  sitePreparationPlans SitePreparationPlan[]

  @@map("project_floor_plans")
}

// Numbered pin dropped on a floor plan for Phase 1 site prep.
// Replaces the text description fields in SitePreparationPlan.sections (Task 14).
model SitePreparationPin {
  id         String              @id @default(uuid()) @db.Uuid
  planId     String              @map("plan_id") @db.Uuid
  plan       SitePreparationPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  categoryId Int                 @map("category_id")
  pinX       Float               @map("pin_x")
  pinY       Float               @map("pin_y")
  label      String

  @@index([planId])
  @@map("site_preparation_pins")
}

// Records a worker's acceptance of the privacy notice at registration.
model WorkerPrivacyConsent {
  id              String        @id @default(uuid()) @db.Uuid
  workerAccountId String        @unique @map("worker_account_id") @db.Uuid
  workerAccount   WorkerAccount @relation(fields: [workerAccountId], references: [id], onDelete: Cascade)
  acceptedAt      DateTime      @map("accepted_at")
  ipAddress       String?       @map("ip_address")
  version         String        @default("1.0")

  @@map("worker_privacy_consents")
}
