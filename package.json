{
  "name": "agero-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:safety": "turbo run dev --filter=@agero/safety",
    "dev:projects": "turbo run dev --filter=@agero/projects",
    "build": "turbo run build",
    "build:safety": "turbo run build --filter=@agero/safety",
    "build:projects": "turbo run build --filter=@agero/projects",
    "lint": "turbo run lint",
    "db:push": "turbo run db:push --filter=@agero/db",
    "db:generate": "turbo run db:generate --filter=@agero/db",
    "db:seed": "turbo run db:seed --filter=@agero/db",
    "db:studio": "turbo run db:studio --filter=@agero/db"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
