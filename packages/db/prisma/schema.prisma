// 7.6 Consolidated Action Register (most important IMS feature)
model ImsAction {
  id              String             @id @default(cuid())
  organisationId  String
  sourceType      ImsActionSourceType
  sourceId        String
  status          ImsActionStatus    @default(OPEN)
  itemNo          Int?
  details         String
  attachmentUrl   String?
  expectedCompDate DateTime?
  completedDate   DateTime?
  responsibleId   String?
  responsible     ImsEmployee?       @relation("ActionResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  contextId       String?
  context         ImsContext?        @relation("ActionFromContext", fields: [contextId], references: [id], onDelete: SetNull)
  meetingId       String?
  meeting         ImsMeeting?        @relation("ActionFromMeeting", fields: [meetingId], references: [id], onDelete: SetNull)
  auditId         String?
  audit           ImsAudit?          @relation(fields: [auditId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([responsibleId])
  @@index([organisationId])
  @@map("ims_actions")
  @@schema("ims")
}

