  providerId       String?
  provider         ImsTrainingProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  supplierId       String?
  required         Boolean @default(false)
  targetDate       DateTime?
  completedDate    DateTime?
  expiryDate       DateTime?
  certNumber       String?
  certLink         String?
  trainingRebooked String?
  cost             Decimal?
  details          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("ims_training_records")
  @@schema("ims")
}

model ImsDocument {
  id          String  @id @default(cuid())
  docNo       String  @unique
  name        String
  docGroup    String?
  active      Boolean @default(true)
  intDoc      Boolean @default(false)
  fieldDoc    Boolean @default(false)
