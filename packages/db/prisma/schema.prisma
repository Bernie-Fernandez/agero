// ─────────────────────────────────────────────────────────────────────────────
// DESIGN STUDIO — design schema
// ─────────────────────────────────────────────────────────────────────────────

enum DesignSourceType {
  GLOBAL
  NON_GLOBAL

  @@schema("design")
}

enum DesignSourceCategory {
  COMPLIANCE
  PAST_PROJECT
  DESIGN_RULES
  RESEARCH_TRENDS
  CLIENT_BRIEF
  CHATBOT_LEARNING
  OTHER

  @@schema("design")
}

enum DesignIndustryTag {
  OFFICE
  RETAIL
  HOSPITALITY
  EDUCATION
  HEALTHCARE
  MIXED
  ALL

  @@schema("design")
}

enum DesignFileType {
  PDF
  DOCX

  @@schema("design")
}

enum DesignSourceStatus {
  PENDING_APPROVAL
  PENDING_INDEX
  INDEXED
  FAILED
  EXPIRED

  @@schema("design")
}

enum DesignSettingStatus {
  ACTIVE
  INACTIVE

  @@schema("design")
}

enum DesignProposalStatus {
  PENDING
  APPROVED
  REJECTED

  @@schema("design")
}

enum DesignFetchSchedule {
  MANUAL
  DAILY
  WEEKLY

  @@schema("design")
}

enum DesignTrendSourceType {
  RSS
  MONITORED_URL
  MANUAL

  @@schema("design")
}

enum DesignTrendStatus {
  NEW
  ADDED_TO_SOURCES
  DISMISSED

  @@schema("design")
}

enum DesignChatRole {
  USER
  ASSISTANT

  @@schema("design")
}

model DesignSource {
  id             String               @id @default(cuid())
  organisationId String               @map("organisation_id") @db.Uuid
  organisation   Organisation         @relation(fields: [organisationId], references: [id])
  title          String
  type           DesignSourceType
  category       DesignSourceCategory
  industryTag    DesignIndustryTag    @map("industry_tag")
  filePath       String?              @map("file_path")
  fileType       DesignFileType?      @map("file_type")
  url            String?
  fetchedContent String?              @map("fetched_content") @db.Text
  status         DesignSourceStatus   @default(PENDING_INDEX)
  isActive       Boolean              @default(true) @map("is_active")
  expiryDate     DateTime             @map("expiry_date")
  expiryReminderSent Boolean          @default(false) @map("expiry_reminder_sent")
  notes          String?              @db.Text
  versionNumber  Int                  @default(1) @map("version_number")
  submittedById  String               @map("submitted_by_id") @db.Uuid
  submittedBy    User                 @relation("DesignSourceSubmittedBy", fields: [submittedById], references: [id])
  approvedById   String?              @map("approved_by_id") @db.Uuid
  approvedBy     User?                @relation("DesignSourceApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?            @map("approved_at")
  rejectionReason String?             @map("rejection_reason") @db.Text
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  versions       DesignSourceVersion[]
  trendItems     DesignTrendItem[]     @relation("TrendItemSource")
  chatbotSessions DesignChatbotSession[]

  @@map("design_source")
  @@schema("design")
}

model DesignSourceVersion {
  id            String       @id @default(cuid())
  sourceId      String       @map("source_id")
  source        DesignSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  versionNumber Int          @map("version_number")
  title         String
  notes         String?      @db.Text
  filePath      String?      @map("file_path")
  url           String?
  isActive      Boolean      @map("is_active")
  changeSummary String?      @map("change_summary") @db.Text
  changedById   String       @map("changed_by_id") @db.Uuid
  changedBy     User         @relation("DesignSourceVersionChangedBy", fields: [changedById], references: [id])
  changedAt     DateTime     @default(now()) @map("changed_at")

  @@map("design_source_version")
  @@schema("design")
}

model DesignSettingGlobal {
  id             String    @id @default(cuid())
  organisationId String    @map("organisation_id") @db.Uuid
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  key            String
  label          String
  value          String    @db.Text
  description    String?   @db.Text
  category       String
  createdById    String    @map("created_by_id") @db.Uuid
  createdBy      User      @relation("DesignGlobalSettingCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  auditLogs      DesignSettingGlobalAudit[]

  @@unique([organisationId, key])
  @@map("design_setting_global")
  @@schema("design")
}

model DesignSettingGlobalAudit {
  id            String              @id @default(cuid())
  settingId     String              @map("setting_id")
  setting       DesignSettingGlobal @relation(fields: [settingId], references: [id], onDelete: Cascade)
  previousValue String              @map("previous_value") @db.Text
  newValue      String              @map("new_value") @db.Text
  reason        String?             @db.Text
  changedById   String              @map("changed_by_id") @db.Uuid
  changedBy     User                @relation("DesignGlobalAuditChangedBy", fields: [changedById], references: [id])
  changedAt     DateTime            @default(now()) @map("changed_at")

  @@map("design_setting_global_audit")
  @@schema("design")
}

model DesignSettingNonGlobal {
  id             String              @id @default(cuid())
  organisationId String              @map("organisation_id") @db.Uuid
  organisation   Organisation        @relation(fields: [organisationId], references: [id])
  key            String
  label          String
  value          String              @db.Text
  description    String?             @db.Text
  category       String
  status         DesignSettingStatus @default(ACTIVE)
  expiryDate     DateTime?           @map("expiry_date")
  createdById    String              @map("created_by_id") @db.Uuid
  createdBy      User                @relation("DesignNonGlobalSettingCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  proposals      DesignSettingNonGlobalProposal[]

  @@unique([organisationId, key])
  @@map("design_setting_nonglobal")
  @@schema("design")
}

model DesignSettingNonGlobalProposal {
  id              String                  @id @default(cuid())
  settingId       String?                 @map("setting_id")
  setting         DesignSettingNonGlobal? @relation(fields: [settingId], references: [id])
  organisationId  String                  @map("organisation_id") @db.Uuid
  organisation    Organisation            @relation(fields: [organisationId], references: [id])
  proposedKey     String                  @map("proposed_key")
  proposedLabel   String                  @map("proposed_label")
  proposedValue   String                  @map("proposed_value") @db.Text
  reason          String?                 @db.Text
  status          DesignProposalStatus    @default(PENDING)
  proposedById    String                  @map("proposed_by_id") @db.Uuid
  proposedBy      User                    @relation("DesignProposalProposedBy", fields: [proposedById], references: [id])
  reviewedById    String?                 @map("reviewed_by_id") @db.Uuid
  reviewedBy      User?                   @relation("DesignProposalReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?               @map("reviewed_at")
  rejectionReason String?                 @map("rejection_reason") @db.Text
  createdAt       DateTime                @default(now()) @map("created_at")

  @@map("design_setting_nonglobal_proposal")
  @@schema("design")
}

model DesignExpiryConfig {
  id                   String       @id @default(cuid())
  organisationId       String       @unique @map("organisation_id") @db.Uuid
  organisation         Organisation @relation(fields: [organisationId], references: [id])
  defaultExpiryMonths  Int          @default(12) @map("default_expiry_months")
  reminderDaysBefore   Int          @default(30) @map("reminder_days_before")
  updatedById          String       @map("updated_by_id") @db.Uuid
  updatedBy            User         @relation("DesignExpiryConfigUpdatedBy", fields: [updatedById], references: [id])
  updatedAt            DateTime     @updatedAt @map("updated_at")

  @@map("design_expiry_config")
  @@schema("design")
}

model DesignRssFeed {
  id            String    @id @default(cuid())
  organisationId String   @map("organisation_id") @db.Uuid
  organisation  Organisation @relation(fields: [organisationId], references: [id])
  name          String
  url           String
  isActive      Boolean   @default(true) @map("is_active")
  lastFetchedAt DateTime? @map("last_fetched_at")
  createdById   String    @map("created_by_id") @db.Uuid
  createdBy     User      @relation("DesignRssFeedCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  trendItems    DesignTrendItem[]

  @@map("design_rss_feed")
  @@schema("design")
}

model DesignMonitoredUrl {
  id               String              @id @default(cuid())
  organisationId   String              @map("organisation_id") @db.Uuid
  organisation     Organisation        @relation(fields: [organisationId], references: [id])
  name             String
  url              String
  fetchSchedule    DesignFetchSchedule @default(DAILY) @map("fetch_schedule")
  isActive         Boolean             @default(true) @map("is_active")
  lastFetchedAt    DateTime?           @map("last_fetched_at")
  lastContentHash  String?             @map("last_content_hash")
  createdById      String              @map("created_by_id") @db.Uuid
  createdBy        User                @relation("DesignMonitoredUrlCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  trendItems       DesignTrendItem[]

  @@map("design_monitored_url")
  @@schema("design")
}

model DesignTrendItem {
  id               String                @id @default(cuid())
  organisationId   String                @map("organisation_id") @db.Uuid
  organisation     Organisation          @relation(fields: [organisationId], references: [id])
  title            String
  sourceName       String                @map("source_name")
  sourceType       DesignTrendSourceType @map("source_type")
  url              String?
  excerpt          String?               @db.Text
  engagementScore  Int?                  @map("engagement_score")
  publishedAt      DateTime?             @map("published_at")
  fetchedAt        DateTime              @default(now()) @map("fetched_at")
  status           DesignTrendStatus     @default(NEW)
  rssFeedId        String?               @map("rss_feed_id")
  rssFeed          DesignRssFeed?        @relation(fields: [rssFeedId], references: [id])
  monitoredUrlId   String?               @map("monitored_url_id")
  monitoredUrl     DesignMonitoredUrl?   @relation(fields: [monitoredUrlId], references: [id])
  submittedById    String?               @map("submitted_by_id") @db.Uuid
  submittedBy      User?                 @relation("DesignTrendItemSubmittedBy", fields: [submittedById], references: [id])
  addedToSourceId  String?               @map("added_to_source_id")
  addedToSource    DesignSource?         @relation("TrendItemSource", fields: [addedToSourceId], references: [id])
  createdAt        DateTime              @default(now()) @map("created_at")

  @@map("design_trend_item")
  @@schema("design")
}

model DesignChatbotSession {
  id             String       @id @default(cuid())
  organisationId String       @map("organisation_id") @db.Uuid
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  userId         String       @map("user_id") @db.Uuid
  user           User         @relation("DesignChatbotSessionUser", fields: [userId], references: [id])
  title          String?
  summary        String?      @db.Text
  sourceId       String?      @map("source_id")
  source         DesignSource? @relation(fields: [sourceId], references: [id])
  startedAt      DateTime     @default(now()) @map("started_at")
  endedAt        DateTime?    @map("ended_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  messages       DesignChatbotMessage[]

  @@map("design_chatbot_session")
  @@schema("design")
}

model DesignChatbotMessage {
  id        String                @id @default(cuid())
  sessionId String                @map("session_id")
  session   DesignChatbotSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      DesignChatRole
  content   String                @db.Text
  createdAt DateTime              @default(now()) @map("created_at")

  @@map("design_chatbot_message")
  @@schema("design")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — estimating (projects schema)
// ─────────────────────────────────────────────────────────────────────────────

enum EstimateStatus {
  DRAFT
  ACTIVE
  CONVERTED
  ARCHIVED

  @@schema("projects")
}

enum EstimateLineType {
  LABOUR
  MATERIAL
  SUBCONTRACTOR
  ALLOWANCE
  PROVISIONAL_SUM

  @@schema("projects")
}

enum EstimateLineStructure {
  SECTION_HEADER
  SUB_HEADING
  STANDARD_LINE
  NOTE_LINE
  PROJECT_SUM_LINE

  @@schema("projects")
}

enum QuoteStatus {
  PENDING
  RECEIVED
  AWARDED
  DECLINED

  @@schema("projects")
}

enum TradeLetStatus {
  NOT_STARTED
  QUOTING
  AWARDED
  COMPLETE

  @@schema("projects")
}

// ─────────────────────────────────────────────────────────────────────────────
// ESTIMATING MODELS — projects schema
// ─────────────────────────────────────────────────────────────────────────────

model Estimate {
  id                   String         @id @default(uuid()) @db.Uuid
  organisationId       String         @map("organisation_id") @db.Uuid
  organisation         Organisation   @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  leadNumber           String         @unique @map("lead_number")
  title                String
  clientId             String?        @map("client_id") @db.Uuid
  client               Company?       @relation("EstimateClient", fields: [clientId], references: [id], onDelete: SetNull)
  status               EstimateStatus @default(DRAFT)
  pipelineStage        Int            @default(3) @map("pipeline_stage")
  confidencePct        Int?           @map("confidence_pct")
  hubspotDealId        String?        @map("hubspot_deal_id")
  addressStreet        String?        @map("address_street")
  addressSuburb        String?        @map("address_suburb")
  addressState         String?        @map("address_state")
  addressPostcode      String?        @map("address_postcode")
  jobType              String?        @map("job_type")
  floorAreaM2          Decimal?       @map("floor_area_m2") @db.Decimal(10, 2)
  estimatorId          String?        @map("estimator_id") @db.Uuid
  estimator            User?          @relation("EstimateEstimator", fields: [estimatorId], references: [id])
  revenueCostCodeId    String?        @map("revenue_cost_code_id") @db.Uuid
  revenueCostCode      CostCode?      @relation("EstimateRevenueCostCode", fields: [revenueCostCodeId], references: [id])
  targetGpPct          Decimal        @default(22.50) @map("target_gp_pct") @db.Decimal(5, 2)
  minGpPct             Decimal        @default(15.00) @map("min_gp_pct") @db.Decimal(5, 2)
  defaultMarkupPct     Decimal        @default(48.15) @map("default_markup_pct") @db.Decimal(5, 2)
  costRecoveryPct      Decimal        @default(10.00) @map("cost_recovery_pct") @db.Decimal(5, 2)
  budgetCoverageTarget Decimal        @default(70.00) @map("budget_coverage_target") @db.Decimal(5, 2)
  declaredMarginDefaultPct Decimal?   @map("declared_margin_default_pct") @db.Decimal(5, 2)
  tradePackageHighPct  Decimal?       @map("trade_package_high_pct") @db.Decimal(5, 2)
  tradePackageMedPct   Decimal?       @map("trade_package_med_pct") @db.Decimal(5, 2)
  tradePackageLowPct   Decimal?       @map("trade_package_low_pct") @db.Decimal(5, 2)
  marketEvalHighPct    Decimal?       @map("market_eval_high_pct") @db.Decimal(5, 2)
  marketEvalMedPct     Decimal?       @map("market_eval_med_pct") @db.Decimal(5, 2)
  marketEvalLowPct     Decimal?       @map("market_eval_low_pct") @db.Decimal(5, 2)
  currencySymbol       String         @default("$") @map("currency_symbol")
  costPerUnitLabel     String?        @map("cost_per_unit_label")
  taxCodeName          String         @default("GST") @map("tax_code_name")
  notes                String?        @db.Text
  convertedToProjectId String?        @map("converted_to_project_id") @db.Uuid
  convertedToProject   Project?       @relation("EstimateConvertedProject", fields: [convertedToProjectId], references: [id], onDelete: SetNull)
  createdById          String         @map("created_by_id") @db.Uuid
  createdBy            User           @relation("EstimateCreatedBy", fields: [createdById], references: [id])
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  areas          EstimateArea[]
  scenarios      EstimateScenario[]
  tradeSections  EstimateTradeSection[]
  lines          EstimateLine[]
  options        EstimateOption[]
  lockaways      EstimateLockaway[]
  insightTags    EstimateInsightTag[]
  tradePackages  TradePackage[]
  snapshots      EstimateSnapshot[]

  @@index([organisationId])
  @@map("estimates")
  @@schema("projects")
}

model EstimateArea {
  id         String   @id @default(uuid()) @db.Uuid
  estimateId String   @map("estimate_id") @db.Uuid
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name       String
  order      Int      @default(0)

  lines EstimateLine[]

  @@index([estimateId])
  @@map("estimate_areas")
  @@schema("projects")
}

model EstimateScenario {
  id         String   @id @default(uuid()) @db.Uuid
  estimateId String   @map("estimate_id") @db.Uuid
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name       String
  isBase     Boolean  @default(false) @map("is_base")
  order      Int      @default(0)

  lines EstimateLine[]

  @@index([estimateId])
  @@map("estimate_scenarios")
  @@schema("projects")
}

model EstimateTradeSection {
  id             String    @id @default(uuid()) @db.Uuid
  organisationId String?   @map("organisation_id") @db.Uuid
  estimateId     String?   @map("estimate_id") @db.Uuid
  estimate       Estimate? @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name           String
  code           String?
  order          Int       @default(0)

  lines          EstimateLine[]
  tradePackages  TradePackage[]
  scopeItems     ScopeLibraryItem[]

  @@index([estimateId])
  @@map("estimate_trade_sections")
  @@schema("projects")
}

model EstimateLine {
  id              String               @id @default(uuid()) @db.Uuid
  estimateId      String               @map("estimate_id") @db.Uuid
  estimate        Estimate             @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  areaId          String?              @map("area_id") @db.Uuid
  area            EstimateArea?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
  scenarioId      String?              @map("scenario_id") @db.Uuid
  scenario        EstimateScenario?    @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  tradeSectionId  String?              @map("trade_section_id") @db.Uuid
  tradeSection    EstimateTradeSection? @relation(fields: [tradeSectionId], references: [id], onDelete: SetNull)
  description     String
  lineStructure   EstimateLineStructure @default(STANDARD_LINE) @map("line_structure")
  lineCode        String?              @map("line_code")
  type            EstimateLineType     @default(MATERIAL)
  quantity        Decimal              @default(0) @db.Decimal(14, 4)
  unit            String?
  rate            Decimal              @default(0) @db.Decimal(14, 4)
  total           Decimal              @default(0) @db.Decimal(14, 2)
  markupPct       Decimal?             @map("markup_pct") @db.Decimal(5, 2)
  isRisk          Boolean              @default(false) @map("is_risk")
  isOption        Boolean              @default(false) @map("is_option")
  isPcSum         Boolean              @default(false) @map("is_pc_sum")
  isLockaway      Boolean              @default(false) @map("is_lockaway")
  isHidden           Boolean              @default(false) @map("is_hidden")
  declaredMarginPct  Decimal?             @map("declared_margin_pct") @db.Decimal(5, 2)
  tradePackageId     String?              @map("trade_package_id") @db.Uuid
  tradePackage       TradePackage?        @relation("EstimateLinePackage", fields: [tradePackageId], references: [id], onDelete: SetNull)
  notes              String?              @db.Text
  order              Int                  @default(0)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  quantities       EstimateLineQuantity[]
  tags             EstimateLineTag[]
  optionLines      EstimateOptionLine[]
  lockawayLines    EstimateLockawayLine[]
  scopeAttachments EstimateLineScopeAttachment[]

  @@index([estimateId])
  @@map("estimate_lines")
  @@schema("projects")
}

model EstimateLineQuantity {
  id       String       @id @default(uuid()) @db.Uuid
  lineId   String       @map("line_id") @db.Uuid
  line     EstimateLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  label    String
  quantity Decimal      @default(0) @db.Decimal(14, 4)

  @@index([lineId])
  @@map("estimate_line_quantities")
  @@schema("projects")
}

model EstimateOption {
  id          String   @id @default(uuid()) @db.Uuid
  estimateId  String   @map("estimate_id") @db.Uuid
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  totalCost   Decimal  @default(0) @map("total_cost") @db.Decimal(14, 2)

  lines EstimateOptionLine[]

  @@index([estimateId])
  @@map("estimate_options")
  @@schema("projects")
}

model EstimateOptionLine {
  id       String         @id @default(uuid()) @db.Uuid
  optionId String         @map("option_id") @db.Uuid
  option   EstimateOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  lineId   String         @map("line_id") @db.Uuid
  line     EstimateLine   @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@unique([optionId, lineId])
  @@map("estimate_option_lines")
  @@schema("projects")
}

model EstimateLockaway {
  id         String   @id @default(uuid()) @db.Uuid
  estimateId String   @map("estimate_id") @db.Uuid
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name       String
  notes      String?  @db.Text

  lines EstimateLockawayLine[]

  @@index([estimateId])
  @@map("estimate_lockaways")
  @@schema("projects")
}

model EstimateLockawayLine {
  id          String           @id @default(uuid()) @db.Uuid
  lockawayId  String           @map("lockaway_id") @db.Uuid
  lockaway    EstimateLockaway @relation(fields: [lockawayId], references: [id], onDelete: Cascade)
  lineId      String           @map("line_id") @db.Uuid
  line        EstimateLine     @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@unique([lockawayId, lineId])
  @@map("estimate_lockaway_lines")
  @@schema("projects")
}

model EstimateInsightTag {
  id         String   @id @default(uuid()) @db.Uuid
  estimateId String   @map("estimate_id") @db.Uuid
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name       String
  color      String   @default("#6366f1")

  lineAssignments EstimateLineTag[]

  @@index([estimateId])
  @@map("estimate_insight_tags")
  @@schema("projects")
}

model EstimateLineTag {
  id    String             @id @default(uuid()) @db.Uuid
  lineId String            @map("line_id") @db.Uuid
  line   EstimateLine      @relation(fields: [lineId], references: [id], onDelete: Cascade)
  tagId  String            @map("tag_id") @db.Uuid
  tag    EstimateInsightTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([lineId, tagId])
  @@map("estimate_line_tags")
  @@schema("projects")
}

model TradePackage {
  id             String               @id @default(uuid()) @db.Uuid
  estimateId     String               @map("estimate_id") @db.Uuid
  estimate       Estimate             @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  tradeSectionId String?              @map("trade_section_id") @db.Uuid
  tradeSection   EstimateTradeSection? @relation(fields: [tradeSectionId], references: [id], onDelete: SetNull)
  name           String
  scope          String?              @db.Text
  status         TradeLetStatus       @default(NOT_STARTED)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  quotes        TradeQuote[]
  assignedLines EstimateLine[] @relation("EstimateLinePackage")

  @@index([estimateId])
  @@map("trade_packages")
  @@schema("projects")
}

model TradeQuote {
  id                String       @id @default(uuid()) @db.Uuid
  packageId         String       @map("package_id") @db.Uuid
  package           TradePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  subcontractorId   String?      @map("subcontractor_id") @db.Uuid
  subcontractor     Company?     @relation("TradeQuoteSubcontractor", fields: [subcontractorId], references: [id], onDelete: SetNull)
  amount            Decimal?     @db.Decimal(14, 2)
  status            QuoteStatus  @default(PENDING)
  receivedAt        DateTime?    @map("received_at")
  notes             String?      @db.Text
  createdAt         DateTime     @default(now()) @map("created_at")

  @@index([packageId])
  @@map("trade_quotes")
  @@schema("projects")
}

model EstimateSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  estimateId   String   @map("estimate_id") @db.Uuid
  estimate     Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  label        String
  snapshotData Json     @map("snapshot_data")
  createdById  String   @map("created_by_id") @db.Uuid
  createdBy    User     @relation("EstimateSnapshotCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([estimateId])
  @@map("estimate_snapshots")
  @@schema("projects")
}

model ScopeLibraryItem {
  id             String                @id @default(uuid()) @db.Uuid
  organisationId String                @map("organisation_id") @db.Uuid
  tradeSectionId String?               @map("trade_section_id") @db.Uuid
  tradeSection   EstimateTradeSection? @relation(fields: [tradeSectionId], references: [id], onDelete: SetNull)
  description    String
  unit           String?
  notes          String?               @db.Text
  isGlobal       Boolean               @default(false) @map("is_global")
  createdAt      DateTime              @default(now()) @map("created_at")

  attachments EstimateLineScopeAttachment[]

  @@index([organisationId])
  @@map("scope_library_items")
  @@schema("projects")
}

model EstimateLineScopeAttachment {
  id               String           @id @default(uuid()) @db.Uuid
  lineId           String           @map("line_id") @db.Uuid
  line             EstimateLine     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  scopeLibraryItemId String         @map("scope_library_item_id") @db.Uuid
  scopeItem        ScopeLibraryItem @relation(fields: [scopeLibraryItemId], references: [id], onDelete: Cascade)

  @@unique([lineId, scopeLibraryItemId])
  @@map("estimate_line_scope_attachments")
  @@schema("projects")
}
