  id              String              @id @default(cuid())
  assetId         String
  asset           ImsAsset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  invoiceDate     DateTime?
  maintType       ImsMaintenanceType
  workDescription String?
  invoiceNo       String?
  invoiceFile     String?
  invAmount       Decimal?
  supplierId      String?

