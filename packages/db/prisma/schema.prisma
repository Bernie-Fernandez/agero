// 7.1 People Domain

model ImsEmployee {
  id                   String       @id @default(cuid())
  organisationId       String
  userId               String?      @unique
  username             String       @unique
  firstName            String
  companyOrSurname     String
  usergroup            ImsUsergroup @default(EMPLOYEE)
  active               Boolean      @default(true)
  dailyChargeOutRate   Decimal?
  addressL1            String?
  addressL2            String?
  suburb               String?
  state                String?
  postcode             String?
  dateOfBirth          DateTime?
  phone                String?
  email                String?      @unique
  mobile               String?
  personalEmail        String?
  sicknessAllergies    String?
  emergencyContactName String?
  emergencyRelationship String?
  emergencyPhone       String?
  preferredDrName      String?
  drAddress            String?
  drPhone              String?
  drFaxEmail           String?
  reportsToId          String?
  reportsTo            ImsEmployee? @relation("EmployeeReportsTo", fields: [reportsToId], references: [id], onDelete: SetNull)
  reportees            ImsEmployee[] @relation("EmployeeReportsTo")
  jobDescription       String?
  jobDescSigned        Boolean      @default(false)
  startDate            DateTime?
  finishDate           DateTime?
  probationEnd         DateTime?
  prevExperience       String?
  bankAccountName      String?
  bsb                  String?
  accountNo            String?
  ppeIssued            Boolean      @default(false)
  medicalCompleted     Boolean      @default(false)
  photoLink            String?
  comments             String?
  myobId               String?
  usi                  String?

